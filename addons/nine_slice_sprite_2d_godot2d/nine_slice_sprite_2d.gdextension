[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 =     "target/debug/libnine_slice_sprite_2d.so"
linux.release.x86_64 =   "target/release/libnine_slice_sprite_2d.so"
windows.debug.x86_64 =   "target/debug/nine_slice_sprite_2d.dll"
windows.release.x86_64 = "target/release/nine_slice_sprite_2d.dll"
macos.debug =            "target/debug/libnine_slice_sprite_2d.dylib"
macos.release =          "target/release/libnine_slice_sprite_2d.dylib"
macos.debug.arm64 =      "target/debug/libnine_slice_sprite_2d.dylib"
macos.release.arm64 =    "target/release/libnine_slice_sprite_2d.dylib"
android.debug.arm64 =    "target/aarch64-linux-android/debug/libnine_slice_sprite_2d.so"
android.release.arm64 =  "target/aarch64-linux-android/release/libnine_slice_sprite_2d.so"
