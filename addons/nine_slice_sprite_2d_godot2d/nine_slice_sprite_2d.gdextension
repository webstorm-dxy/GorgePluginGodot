[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.2
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://addons/nine_slice_sprite_2d_godot2d/target/debug/libnine_slice_sprite_2d.so"
linux.release.x86_64 =   "res://addons/nine_slice_sprite_2d_godot2d/target/release/libnine_slice_sprite_2d.so"
windows.debug.x86_64 =   "res://addons/nine_slice_sprite_2d_godot2d/target/debug/nine_slice_sprite_2d.dll"
windows.release.x86_64 = "res://addons/nine_slice_sprite_2d_godot2d/target/release/nine_slice_sprite_2d.dll"
macos.debug =            "res://addons/nine_slice_sprite_2d_godot2d/target/debug/libnine_slice_sprite_2d.dylib"
macos.release =          "res://addons/nine_slice_sprite_2d_godot2d/target/release/libnine_slice_sprite_2d.dylib"
macos.debug.arm64 =      "res://addons/nine_slice_sprite_2d_godot2d/target/debug/libnine_slice_sprite_2d.dylib"
macos.release.arm64 =    "res://addons/nine_slice_sprite_2d_godot2d/target/release/libnine_slice_sprite_2d.dylib"
android.debug.arm64 =    "res://addons/nine_slice_sprite_2d_godot2d/target/aarch64-linux-android/debug/libnine_slice_sprite_2d.so"
android.release.arm64 =  "res://addons/nine_slice_sprite_2d_godot2d/target/aarch64-linux-android/release/libnine_slice_sprite_2d.so"
android.template_debug.arm64 =    "res://addons/nine_slice_sprite_2d_godot2d/target/aarch64-linux-android/debug/libnine_slice_sprite_2d.so"
android.template_release.arm64 =  "res://addons/nine_slice_sprite_2d_godot2d/target/aarch64-linux-android/release/libnine_slice_sprite_2d.so"
